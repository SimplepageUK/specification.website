---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { categories, site } from '~/lib/site';
import { getCollection } from 'astro:content';

const allSpec = await getCollection('spec', ({ data }) => !data.draft);
const counts: Record<string, number> = {};
for (const e of allSpec) counts[e.data.category] = (counts[e.data.category] ?? 0) + 1;
const total = allSpec.length;
---

<BaseLayout
  title={site.name}
  description={site.description}
  bare={false}
>
  <section class="border-b border-ink-200 bg-gradient-to-b from-accent-50/60 to-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
      <p class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-medium text-accent-800 ring-1 ring-inset ring-accent-200">
        <span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>
        Living spec · v0.1 · MIT licensed
      </p>
      <h1 class="mt-4 max-w-4xl text-balance text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        What a good website does.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-700 sm:text-xl">
        A platform-agnostic specification of the technical features every
        decent website should have — from <code class="rounded bg-white px-1.5 py-0.5 text-base text-accent-800 ring-1 ring-inset ring-ink-200">&lt;title&gt;</code>
        to <code class="rounded bg-white px-1.5 py-0.5 text-base text-accent-800 ring-1 ring-inset ring-ink-200">/.well-known/security.txt</code>,
        from WCAG contrast to <code class="rounded bg-white px-1.5 py-0.5 text-base text-accent-800 ring-1 ring-inset ring-ink-200">llms.txt</code>.
        Written for humans and agents.
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a href="/spec/" class="inline-flex items-center gap-1.5 rounded-md bg-accent-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-accent-800">
          Browse all {total} topics →
        </a>
        <a href="/checklist/" class="inline-flex items-center gap-1.5 rounded-md border border-ink-300 bg-white px-4 py-2.5 text-sm font-medium text-ink-800 hover:border-ink-400">
          Get the checklist
        </a>
        <a href={site.repo} rel="external" class="inline-flex items-center gap-1.5 rounded-md px-2 py-2 text-sm font-medium text-ink-700 hover:text-accent-700">
          ★ on GitHub
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">Categories</h2>
        <p class="mt-1 text-ink-600">Ten areas, mapped to widely-accepted standards.</p>
      </div>
      <a href="/spec/" class="hidden text-sm text-accent-700 hover:text-accent-800 sm:inline">All topics →</a>
    </div>
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((c) => (
        <li>
          <a href={`/spec/${c.slug}/`} class="group block h-full rounded-xl border border-ink-200 bg-white p-5 transition hover:border-accent-300 hover:shadow-sm">
            <div class="flex items-baseline justify-between gap-2">
              <h3 class="text-lg font-semibold text-ink-900 group-hover:text-accent-700">{c.title}</h3>
              <span class="font-mono text-xs text-ink-500">{counts[c.slug] ?? 0}</span>
            </div>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-600">{c.summary}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="bg-ink-50 py-14">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 md:grid-cols-3">
      <div>
        <h3 class="text-base font-semibold text-ink-900">Standards, not opinions</h3>
        <p class="mt-2 text-sm text-ink-600">Each topic links back to the source standard — WHATWG, W3C, IETF RFCs, WCAG, MDN, and the organisations defining the modern web.</p>
      </div>
      <div>
        <h3 class="text-base font-semibold text-ink-900">Platform agnostic</h3>
        <p class="mt-2 text-sm text-ink-600">Whether you ship WordPress, Next.js, Hugo, plain HTML, or a Django app, the spec is the spec. Implementation hints follow it, not the other way round.</p>
      </div>
      <div>
        <h3 class="text-base font-semibold text-ink-900">Built in the open</h3>
        <p class="mt-2 text-sm text-ink-600">Every page has an <a class="underline" href={site.repo}>Edit on GitHub</a> link. PRs welcome. Sources credited on every page.</p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14">
    <h2 class="text-2xl font-bold text-ink-900 sm:text-3xl">How to use this site</h2>
    <ol class="mt-6 grid gap-5 md:grid-cols-3">
      <li class="rounded-lg border border-ink-200 bg-white p-5">
        <span class="font-mono text-xs text-ink-500">01</span>
        <h3 class="mt-1 font-semibold text-ink-900">Audit</h3>
        <p class="mt-2 text-sm text-ink-600">Run through the <a class="underline" href="/checklist/">checklist</a>. Each item is a “does the site do this — yes or no.”</p>
      </li>
      <li class="rounded-lg border border-ink-200 bg-white p-5">
        <span class="font-mono text-xs text-ink-500">02</span>
        <h3 class="mt-1 font-semibold text-ink-900">Learn</h3>
        <p class="mt-2 text-sm text-ink-600">Click into any item for what it is, why it matters, and how to implement it.</p>
      </li>
      <li class="rounded-lg border border-ink-200 bg-white p-5">
        <span class="font-mono text-xs text-ink-500">03</span>
        <h3 class="mt-1 font-semibold text-ink-900">Improve</h3>
        <p class="mt-2 text-sm text-ink-600">Found a gap, a stale fact, or a missing topic? Open a PR. Sources required.</p>
      </li>
    </ol>
  </section>
</BaseLayout>

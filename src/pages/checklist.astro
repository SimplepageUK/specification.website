---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import StatusBadge from "~/components/StatusBadge.astro";
import { categories } from "~/lib/site";
import { getCollection } from "astro:content";

const all = await getCollection("spec", ({ data }) => !data.draft);
const grouped: Record<string, typeof all> = {};
for (const e of all) (grouped[e.data.category] ??= []).push(e);
for (const k of Object.keys(grouped)) {
  grouped[k].sort(
    (a, b) =>
      a.data.order - b.data.order || a.data.title.localeCompare(b.data.title),
  );
}
---

<BaseLayout
  title="The checklist"
  description="The Website Specification as a flat checklist — required, recommended, optional. Print-friendly."
  ogImage="/og/checklist.png"
>
  <div class="mx-auto max-w-4xl px-4 py-10">
    <Breadcrumbs
      crumbs={[{ label: "Home", href: "/" }, { label: "Checklist" }]}
    />
    <header class="mt-5 border-b border-ink-200 pb-5">
      <h1 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        The checklist
      </h1>
      <p class="mt-2 text-ink-600">
        Every spec item, flat and tickable. Use as a self-audit. Print-friendly.
      </p>
    </header>

    <div class="mt-8 space-y-10">
      {
        categories.map((c) => {
          const items = grouped[c.slug] ?? [];
          if (!items.length) return null;
          return (
            <section>
              <h2 class="text-xl font-bold text-ink-900">{c.title}</h2>
              <p class="text-sm text-ink-600">{c.summary}</p>
              <ul class="mt-3 divide-y divide-ink-100 rounded-lg border border-ink-200 bg-ink-50">
                {items.map((entry) => (
                  <li class="flex items-start gap-3 px-4 py-3">
                    <input
                      type="checkbox"
                      class="mt-1.5 h-4 w-4 rounded border-ink-300 text-accent-700 focus:ring-accent-500"
                      aria-label={`Mark ${entry.data.title} done`}
                    />
                    <div class="flex-1">
                      <div class="flex flex-wrap items-baseline gap-2">
                        <a
                          class="text-sm font-medium text-ink-900 hover:text-accent-700"
                          href={`/spec/${entry.data.category}/${entry.data.slug ?? entry.id.split("/").pop()}/`}
                        >
                          {entry.data.title}
                        </a>
                        <StatusBadge status={entry.data.status} />
                      </div>
                      <p class="mt-0.5 text-sm text-ink-600">
                        {entry.data.summary}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</BaseLayout>

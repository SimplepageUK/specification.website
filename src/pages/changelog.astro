---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import { changeTypeColor, changeTypeLabel, site } from "~/lib/site";
import { getCollection, render } from "astro:content";

const entries = await getCollection("changelog", ({ data }) => !data.draft);
entries.sort((a, b) => b.data.date.localeCompare(a.data.date));

// Pre-render each entry body and group by month for the timeline headings.
const rendered = await Promise.all(
  entries.map(async (entry) => ({
    entry,
    Content: (await render(entry)).Content,
  })),
);

const monthFmt = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "long",
});
const dayFmt = new Intl.DateTimeFormat("en-GB", {
  day: "numeric",
  month: "short",
  year: "numeric",
});

type Group = { label: string; items: typeof rendered };
const groups: Group[] = [];
for (const item of rendered) {
  const label = monthFmt.format(new Date(item.entry.data.date));
  const last = groups[groups.length - 1];
  if (last && last.label === label) last.items.push(item);
  else groups.push({ label, items: [item] });
}
---

<BaseLayout
  title="Changelog"
  description="What changed in The Website Specification — new topics, status changes, and removals, newest first."
  ogImage="/og/changelog.png"
>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs
      crumbs={[{ label: "Home", href: "/" }, { label: "Changelog" }]}
    />
    <header class="mt-5 border-b border-ink-200 pb-5">
      <h1 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Changelog
      </h1>
      <p class="mt-2 text-ink-600">
        What changed in the spec — new topics, status changes, and honest
        removals, newest first. Subscribe via <a
          class="underline hover:text-accent-700"
          href="/rss.xml">RSS</a
        >.
      </p>
    </header>

    <div class="mt-10 space-y-12">
      {
        groups.map((group) => (
          <section>
            <h2 class="text-xs font-semibold tracking-wide text-ink-500 uppercase">
              {group.label}
            </h2>
            <ol class="mt-4 space-y-8 border-l border-ink-200 pl-6">
              {group.items.map(({ entry, Content }) => (
                <li class="relative">
                  <span
                    class="absolute top-1.5 -left-[1.6875rem] h-2.5 w-2.5 rounded-full border-2 border-ink-50 bg-accent-600"
                    aria-hidden="true"
                  />
                  <div class="flex flex-wrap items-center gap-2">
                    <span
                      class:list={[
                        "inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium",
                        changeTypeColor[entry.data.type],
                      ]}
                    >
                      {changeTypeLabel[entry.data.type]}
                    </span>
                    <time
                      class="text-xs text-ink-500"
                      datetime={entry.data.date}
                    >
                      {dayFmt.format(new Date(entry.data.date))}
                    </time>
                  </div>
                  <h3 class="mt-2 text-lg font-semibold text-ink-900">
                    {entry.data.title}
                  </h3>
                  <div class="prose-spec mt-1 text-ink-600">
                    <Content />
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))
      }
    </div>
  </div>
</BaseLayout>

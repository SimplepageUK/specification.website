---
import { getCollection, render } from 'astro:content';
import SpecLayout from '~/layouts/SpecLayout.astro';
import { categories } from '~/lib/site';

export async function getStaticPaths() {
  const all = await getCollection('spec', ({ data }) => !data.draft);
  return all.map((entry) => {
    const slug = entry.data.slug ?? entry.id.split('/').pop()!;
    return {
      params: { category: entry.data.category, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const all = await getCollection('spec', ({ data }) => !data.draft);
const related = entry.data.relatedSlugs
  .map((rs: string) => {
    const found = all.find((e) => (e.data.slug ?? e.id.split('/').pop()) === rs);
    if (!found) return null;
    return {
      title: found.data.title,
      href: `/spec/${found.data.category}/${found.data.slug ?? found.id.split('/').pop()}/`,
      status: found.data.status,
    };
  })
  .filter(Boolean);

const slug = entry.data.slug ?? entry.id.split('/').pop()!;
---

<SpecLayout
  title={entry.data.title}
  summary={entry.data.summary}
  category={entry.data.category}
  status={entry.data.status}
  sources={entry.data.sources}
  related={related as any}
  updated={entry.data.updated}
  appliesTo={entry.data.appliesTo}
  slug={slug}
>
  <Content />
</SpecLayout>

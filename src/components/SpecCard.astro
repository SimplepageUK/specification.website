---
import StatusBadge from './StatusBadge.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  status: 'required' | 'recommended' | 'optional' | 'avoid';
}

const { href, title, summary, status } = Astro.props;
---

<a
  href={href}
  class="group block rounded-lg border border-ink-200 bg-ink-50 p-4 transition hover:border-accent-300 hover:shadow-sm"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold text-ink-900 group-hover:text-accent-700">{title}</h3>
    <StatusBadge status={status} />
  </div>
  <p class="mt-1.5 text-sm leading-relaxed text-ink-600">{summary}</p>
</a>

---
import { site, categories } from '~/lib/site';
const { pathname } = Astro.url;
---

<header class="border-b border-ink-200 bg-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-4">
    <a href="/" class="flex items-center gap-3 font-semibold text-ink-900 no-underline">
      <span class="grid h-9 w-9 place-items-center rounded-md bg-accent-700 font-mono text-sm text-white" aria-hidden="true">W/</span>
      <span class="leading-tight">
        <span class="block text-base">{site.shortName}</span>
        <span class="block text-xs font-normal text-ink-500">specification.website</span>
      </span>
    </a>
    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-5 text-sm">
        <li><a class="text-ink-700 hover:text-accent-700" href="/spec/">All topics</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/checklist/">Checklist</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/about/">About</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/contribute/">Contribute</a></li>
        <li>
          <a
            href="/search/"
            data-search-trigger
            class="inline-flex items-center gap-2 rounded-md border border-ink-200 bg-white px-2.5 py-1.5 text-xs font-medium text-ink-600 hover:border-ink-300 hover:text-ink-800"
            aria-label="Open search (Command-K)"
          >
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-3.5-3.5"/></svg>
            <span>Search</span>
            <kbd class="ml-1 hidden rounded border border-ink-200 bg-ink-50 px-1 py-px font-mono text-[10px] text-ink-500 lg:inline">⌘K</kbd>
          </a>
        </li>
        <li>
          <a class="inline-flex items-center gap-1.5 rounded-md border border-ink-200 px-2.5 py-1.5 text-xs font-medium text-ink-700 hover:border-ink-300" href={site.repo} rel="external">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.74-3.65 3.94.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </li>
      </ul>
    </nav>
  </div>
  {pathname !== '/' && (
    <div class="border-t border-ink-100 bg-ink-50">
      <nav aria-label="Categories" class="mx-auto max-w-6xl overflow-x-auto px-4">
        <ul class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
          {categories.map((c) => (
            <li>
              <a
                href={`/spec/${c.slug}/`}
                class:list={[
                  'rounded-md px-3 py-1.5 hover:bg-white hover:text-accent-700',
                  pathname.startsWith(`/spec/${c.slug}`)
                    ? 'bg-white text-accent-700 shadow-sm ring-1 ring-ink-200'
                    : 'text-ink-700',
                ]}
              >
                {c.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>

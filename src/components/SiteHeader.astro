---
import { site, categories } from '~/lib/site';
const { pathname } = Astro.url;
---

<header class="sticky top-0 z-40 border-b border-ink-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-3 font-semibold text-ink-900 no-underline">
      <svg
        class="h-9 w-9 shrink-0 rounded-md bg-accent-700"
        viewBox="0 0 64 64"
        role="img"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M12 26 L22 46 L30 31 L38 46 L52 18"
          fill="none"
          stroke="#ffffff"
          stroke-width="6"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <span class="leading-tight">
        <span class="block text-base">{site.shortName}</span>
        <span class="hidden text-xs font-normal text-ink-500 sm:block">What a good website does.</span>
      </span>
    </a>

    {/* Desktop primary nav (≥ md) */}
    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-5 text-sm">
        <li><a class="text-ink-700 hover:text-accent-700" href="/spec/">All topics</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/checklist/">Checklist</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/mcp/">MCP</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/about/">About</a></li>
        <li><a class="text-ink-700 hover:text-accent-700" href="/contribute/">Contribute</a></li>
        <li>
          <a
            href="/search/"
            data-search-trigger
            class="inline-flex items-center gap-2 rounded-md border border-ink-200 bg-white px-2.5 py-1.5 text-xs font-medium text-ink-600 hover:border-ink-300 hover:text-ink-800"
            aria-label="Open search (Command-K)"
          >
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-3.5-3.5"/></svg>
            <span>Search</span>
            <kbd class="ml-1 hidden rounded border border-ink-200 bg-ink-50 px-1 py-px font-mono text-[10px] text-ink-500 lg:inline">⌘K</kbd>
          </a>
        </li>
        <li>
          <a class="inline-flex items-center gap-1.5 rounded-md border border-ink-200 px-2.5 py-1.5 text-xs font-medium text-ink-700 hover:border-ink-300" href={site.repo} rel="external">
            <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.33c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.74-3.65 3.94.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
          </a>
        </li>
      </ul>
    </nav>

    {/* Mobile hamburger (< md) — uses native <details> so no JS, no CSP allowance needed. */}
    <details class="mobile-menu md:hidden">
      <summary
        class="grid h-10 w-10 cursor-pointer place-items-center rounded-md border border-ink-200 text-ink-700 hover:border-ink-300"
        aria-label="Open menu"
      >
        <svg class="mobile-menu__icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="mobile-menu__icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </summary>
      <div class="mobile-menu__panel">
        <nav aria-label="Mobile primary" class="border-b border-ink-100 px-4 py-3">
          <ul class="space-y-1 text-sm">
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/spec/">All topics</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/checklist/">Checklist</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/search/">Search</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/mcp/">MCP server</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/about/">About</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href="/contribute/">Contribute</a></li>
            <li><a class="block rounded-md px-2 py-2 text-ink-800 hover:bg-ink-50" href={site.repo} rel="external">GitHub</a></li>
          </ul>
        </nav>
        <nav aria-label="Mobile categories" class="px-4 py-3">
          <p class="mb-1.5 text-xs font-semibold tracking-wide text-ink-500 uppercase">Categories</p>
          <ul class="grid grid-cols-2 gap-1 text-sm">
            {categories.map((c) => (
              <li>
                <a
                  href={`/spec/${c.slug}/`}
                  class:list={[
                    'block rounded-md px-2 py-2',
                    pathname.startsWith(`/spec/${c.slug}`)
                      ? 'bg-accent-50 text-accent-800 ring-1 ring-inset ring-accent-200'
                      : 'text-ink-800 hover:bg-ink-50',
                  ]}
                >{c.title}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </details>
  </div>

  {pathname !== '/' && (
    <div class="hidden border-t border-ink-100 bg-ink-50 md:block">
      <nav aria-label="Categories" class="mx-auto max-w-6xl overflow-x-auto px-4">
        <ul class="flex items-center gap-1 py-2 text-sm whitespace-nowrap">
          {categories.map((c) => (
            <li>
              <a
                href={`/spec/${c.slug}/`}
                class:list={[
                  'rounded-md px-3 py-1.5 hover:bg-white hover:text-accent-700',
                  pathname.startsWith(`/spec/${c.slug}`)
                    ? 'bg-white text-accent-700 shadow-sm ring-1 ring-ink-200'
                    : 'text-ink-700',
                ]}
              >
                {c.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}
</header>

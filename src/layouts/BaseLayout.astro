---
import '~/styles/global.css';
import { site } from '~/lib/site';
import HeadMeta from '~/components/HeadMeta.astro';
import SiteHeader from '~/components/SiteHeader.astro';
import SiteFooter from '~/components/SiteFooter.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** When true, suppress the default page header (for landing-style pages). */
  bare?: boolean;
  /** Absolute URL of the markdown source for this page, if one exists. */
  markdownUrl?: string;
}

const {
  title,
  description,
  canonical,
  type = 'website',
  noindex = false,
  jsonLd,
  bare = false,
  markdownUrl,
} = Astro.props;

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.description,
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.url}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const finalJsonLd = jsonLd
  ? Array.isArray(jsonLd) ? [websiteJsonLd, ...jsonLd] : [websiteJsonLd, jsonLd]
  : websiteJsonLd;
---

<!doctype html>
<html lang="en-GB" dir="ltr">
  <head>
    <HeadMeta
      title={title}
      description={description}
      canonical={canonical}
      type={type}
      noindex={noindex}
      jsonLd={finalJsonLd}
      markdownUrl={markdownUrl}
    />
    {import.meta.env.PROD && (
      <script
        defer
        data-domain={site.plausibleDomain}
        src={`${site.plausibleHost}/js/script.js`}
      />
    )}
    <slot name="head" />
  </head>
  <body class="bg-white text-ink-800">
    <a href="#main" class="skip-link">Skip to main content</a>
    {!bare && <SiteHeader />}
    <main id="main">
      <slot />
    </main>
    <SiteFooter />

    <dialog id="search-overlay" class="search-overlay" aria-label="Search the specification">
      <div class="search-overlay__inner">
        <div class="search-overlay__bar">
          <span class="text-xs font-medium tracking-wide text-ink-500 uppercase">Search</span>
          <button
            type="button"
            data-search-close
            class="rounded-md p-1 text-ink-500 hover:bg-ink-100 hover:text-ink-700"
            aria-label="Close search"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <div id="search-overlay-mount"></div>
        <div class="search-overlay__foot">
          <span><kbd>esc</kbd> close</span>
          <span><kbd>↑</kbd> <kbd>↓</kbd> navigate</span>
          <span><kbd>↵</kbd> open</span>
        </div>
      </div>
    </dialog>
    <script src="/search-overlay.js" type="text/javascript" defer></script>
    <script src="/webmcp.js" type="text/javascript" defer></script>
  </body>
</html>

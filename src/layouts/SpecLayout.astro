---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import StatusBadge from '~/components/StatusBadge.astro';
import { categoryFor, site } from '~/lib/site';

interface Source { title: string; url: string; publisher?: string }
interface Props {
  title: string;
  summary: string;
  category: string;
  status: 'required' | 'recommended' | 'optional' | 'avoid';
  sources?: Source[];
  related?: { title: string; href: string; status: string }[];
  updated?: string;
  appliesTo?: string[];
  slug: string;
}

const {
  title,
  summary,
  category,
  status,
  sources = [],
  related = [],
  updated,
  appliesTo = ['all'],
  slug,
} = Astro.props;

const cat = categoryFor(category);
const canonical = new URL(`/spec/${category}/${slug}/`, site.url).toString();

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: summary,
  url: canonical,
  inLanguage: 'en',
  isPartOf: { '@type': 'WebSite', name: site.name, url: site.url },
  author: { '@type': 'Person', name: site.author.name, url: site.author.url },
  publisher: { '@type': 'Organization', name: site.name, url: site.url },
  dateModified: updated,
  citation: sources.map((s) => ({ '@type': 'CreativeWork', name: s.title, url: s.url })),
};
---

<BaseLayout title={title} description={summary} canonical={canonical} type="article" jsonLd={articleJsonLd}>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <Breadcrumbs
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Spec', href: '/spec/' },
        { label: cat?.title ?? category, href: `/spec/${category}/` },
        { label: title },
      ]}
    />

    <header class="mt-5 border-b border-ink-200 pb-6">
      <div class="flex flex-wrap items-center gap-2 text-xs">
        {cat && (
          <a href={`/spec/${category}/`} class="rounded-full bg-accent-50 px-2.5 py-0.5 font-medium text-accent-800 no-underline hover:bg-accent-100">{cat.title}</a>
        )}
        <StatusBadge status={status} />
        {updated && <span class="text-ink-500">Updated {updated}</span>}
      </div>
      <h1 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">{title}</h1>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-ink-600">{summary}</p>
      {appliesTo.length > 0 && appliesTo[0] !== 'all' && (
        <p class="mt-3 text-sm text-ink-500">
          <span class="font-medium text-ink-700">Applies to:</span> {appliesTo.join(', ')}
        </p>
      )}
    </header>

    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_240px]">
      <div class="prose-spec">
        <slot />

        {related.length > 0 && (
          <section class="not-prose mt-12 rounded-lg border border-ink-200 bg-ink-50 p-5">
            <h2 class="mb-3 text-base font-semibold text-ink-900">Related topics</h2>
            <ul class="space-y-1.5 text-sm">
              {related.map((r) => (
                <li><a class="text-accent-700 hover:text-accent-800" href={r.href}>{r.title}</a></li>
              ))}
            </ul>
          </section>
        )}

        {sources.length > 0 && (
          <section class="mt-10 border-t border-ink-200 pt-6">
            <h2 class="text-base font-semibold text-ink-900">Sources &amp; further reading</h2>
            <ul class="mt-3 space-y-2 text-sm">
              {sources.map((s) => (
                <li>
                  <a href={s.url} rel="external">{s.title}</a>
                  {s.publisher && <span class="text-ink-500"> — {s.publisher}</span>}
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>

      <aside class="lg:sticky lg:top-6 lg:self-start">
        <div class="rounded-lg border border-ink-200 bg-white p-4 text-sm">
          <p class="text-xs font-semibold tracking-wide text-ink-500 uppercase">On this page</p>
          <div id="toc" class="mt-2 space-y-1 text-sm leading-snug"></div>
        </div>
        <div class="mt-4 rounded-lg border border-ink-200 bg-ink-50 p-4 text-xs text-ink-600">
          <p class="font-semibold text-ink-800">Spot a problem?</p>
          <p class="mt-1">All pages are editable.</p>
          <a class="mt-2 inline-block text-accent-700 underline" href={`${site.repo}/edit/main/src/content/spec/${category}/${slug}.md`} rel="external">
            Edit this page on GitHub →
          </a>
        </div>
      </aside>
    </div>
  </article>

  <script>
    const headings = document.querySelectorAll<HTMLHeadingElement>('.prose-spec h2[id], .prose-spec h3[id]');
    const toc = document.getElementById('toc');
    if (toc && headings.length) {
      const frag = document.createDocumentFragment();
      headings.forEach((h) => {
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent ?? '';
        a.className = h.tagName === 'H3'
          ? 'block pl-3 text-ink-600 hover:text-accent-700 no-underline'
          : 'block text-ink-700 hover:text-accent-700 no-underline';
        frag.appendChild(a);
      });
      toc.appendChild(frag);
    }
  </script>
</BaseLayout>
